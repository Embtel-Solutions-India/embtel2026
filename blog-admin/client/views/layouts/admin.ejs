<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' · Blog Admin' : 'Blog Admin' %></title>
  <link rel="icon" href="/images/favicon.png" />
  <%- include('../partials/tailwind-config') %>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
  <script>
    window.CSRF_TOKEN = "<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>";
    window.CURRENT_USER = <%- typeof currentUser !== 'undefined' && currentUser ? JSON.stringify({ id: currentUser._id, name: currentUser.name, email: currentUser.email, role: currentUser.role }) : 'null' %>;
    window.MAIN_SITE_URL = "<%= mainSiteUrl %>";
  </script>
  <script src="/js/csrf.js"></script>
  <script src="/js/admin.js"></script>
</head>
<body class="font-body bg-ink text-m3 antialiased">
  <div class="flex min-h-screen">
    <%- include('../partials/sidebar') %>

    <div class="flex-1 min-w-0 lg:pl-64 flex flex-col">
      <%- include('../partials/topbar') %>

      <main class="flex-1 p-4 sm:p-6 lg:p-8 animate-fadeUp">
        <div id="toastContainer" class="fixed top-4 right-4 z-[100] flex flex-col gap-2 w-80 max-w-[90vw]"></div>
        <%- body %>
      </main>
    </div>
  </div>

  <%- include('../partials/confirm-modal') %>
</body>
</html>
