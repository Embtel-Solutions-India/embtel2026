<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reset Password · Blog Admin</title>
  <link rel="icon" href="/images/favicon.png" />
  <%- include('../partials/tailwind-config') %>
</head>
<body class="font-body bg-ink text-m3 min-h-screen flex items-center justify-center p-6">
  <script src="/js/csrf.js"></script>

  <div class="w-full max-w-sm animate-fadeUp">
    <div class="flex items-center gap-2 font-heading font-extrabold text-xl text-white mb-8 justify-center">
      <img src="/images/logo.png" alt="Embtel" class="h-8 w-auto" onerror="this.style.display='none'" />
      <span>Blog Admin</span>
    </div>

    <div class="bg-s1 border border-white/10 rounded-r20 p-8">
      <h2 class="font-heading font-extrabold text-2xl text-white mb-6">Set a new password</h2>

      <div id="formAlert" class="hidden mb-4 px-4 py-3 rounded-r8 text-sm bg-red-500/10 border border-red-500/30 text-red-300"></div>

      <form id="resetForm" novalidate class="space-y-5">
        <div>
          <label class="block text-xs font-semibold text-m2 mb-1.5">New password</label>
          <input type="password" name="password" required minlength="8" autofocus
            class="w-full bg-s2 border border-white/10 rounded-r8 px-4 py-2.5 text-white placeholder-m1 outline-none focus:border-brand-teal focus:ring-1 focus:ring-brand-teal transition" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-m2 mb-1.5">Confirm password</label>
          <input type="password" name="confirmPassword" required minlength="8"
            class="w-full bg-s2 border border-white/10 rounded-r8 px-4 py-2.5 text-white placeholder-m1 outline-none focus:border-brand-teal focus:ring-1 focus:ring-brand-teal transition" />
        </div>
        <button type="submit"
          class="w-full flex items-center justify-center gap-2 bg-brand-teal text-ink font-heading font-bold py-3 rounded-r14 hover:brightness-110 active:scale-[0.98] transition disabled:opacity-60">
          <svg id="spinner" class="hidden animate-spin h-4 w-4" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
          Reset Password
        </button>
      </form>
    </div>
  </div>

  <script>
    var resetToken = <%- JSON.stringify(token) %>;
    document.getElementById('resetForm').addEventListener('submit', async function(e){
      e.preventDefault();
      var form = e.target;
      var alertBox = document.getElementById('formAlert');
      var btn = form.querySelector('button[type="submit"]');
      var spinner = document.getElementById('spinner');

      if (form.password.value !== form.confirmPassword.value) {
        alertBox.textContent = 'Passwords do not match.';
        alertBox.classList.remove('hidden');
        return;
      }

      spinner.classList.remove('hidden');
      btn.disabled = true;
      try {
        var res = await fetch('/api/reset-password/' + resetToken, {
          method: 'POST',
          headers: withCsrfHeaders({ 'Content-Type': 'application/json' }),
          credentials: 'include',
          body: JSON.stringify({ password: form.password.value }),
        });
        var data = await res.json();
        if (!res.ok) throw new Error(data.message || 'Reset failed');
        window.location.href = '/admin/dashboard';
      } catch (err) {
        alertBox.textContent = err.message;
        alertBox.classList.remove('hidden');
      } finally {
        spinner.classList.add('hidden');
        btn.disabled = false;
      }
    });
  </script>
</body>
</html>
