<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Log In · Blog Admin</title>
  <link rel="icon" href="/images/favicon.png" />
  <%- include('../partials/tailwind-config') %>
</head>
<body class="font-body bg-ink text-m3 min-h-screen overflow-hidden">
  <script src="/js/csrf.js"></script>

  <div class="grid lg:grid-cols-2 min-h-screen">
    <!-- Left: brand / hero -->
    <div class="relative hidden lg:flex flex-col justify-between p-12 overflow-hidden bg-ink2 border-r border-white/5">
      <div class="absolute -top-40 -left-20 w-[500px] h-[500px] rounded-full bg-brand-blue/20 blur-3xl animate-blob"></div>
      <div class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full bg-brand-teal/10 blur-3xl animate-blob" style="animation-delay:2s"></div>

      <div class="relative flex items-center gap-2 font-heading font-extrabold text-xl text-white">
        <img src="/images/logo.png" alt="Embtel" class="h-8 w-auto" onerror="this.style.display='none'" />
        <span>Blog Admin</span>
      </div>

      <div class="relative max-w-md animate-fadeUp">
        <div class="text-xs font-bold tracking-[2px] uppercase text-brand-blue mb-4">Content Management</div>
        <h1 class="font-heading font-extrabold text-4xl text-white leading-tight tracking-tight mb-4">
          Publish faster. <span class="bg-gradient-to-r from-brand-teal to-brand-blue bg-clip-text text-transparent">Write better.</span>
        </h1>
        <p class="text-m2 text-base leading-relaxed">
          One place to draft, schedule, and publish everything that shows up on your live site — instantly, with zero manual steps.
        </p>
      </div>

      <div class="relative text-xs text-m1">© <%= new Date().getFullYear() %> Embtel Solutions. All rights reserved.</div>
    </div>

    <!-- Right: form -->
    <div class="flex items-center justify-center p-6 sm:p-10 relative">
      <button id="themeToggle" class="absolute top-6 right-6 w-10 h-10 rounded-r8 border border-white/10 flex items-center justify-center text-m2 hover:text-white hover:bg-s1 transition" title="Toggle theme">
        <i data-icon="moon">🌙</i>
      </button>

      <div class="w-full max-w-sm animate-fadeUp">
        <div class="lg:hidden flex items-center gap-2 font-heading font-extrabold text-xl text-white mb-8">
          <img src="/images/logo.png" alt="Embtel" class="h-8 w-auto" onerror="this.style.display='none'" />
          <span>Blog Admin</span>
        </div>

        <h2 class="font-heading font-extrabold text-2xl text-white mb-1">Welcome back</h2>
        <p class="text-m2 text-sm mb-8">Log in to manage your blog.</p>

        <div id="formAlert" class="hidden mb-4 px-4 py-3 rounded-r8 bg-red-500/10 border border-red-500/30 text-red-300 text-sm"></div>

        <form id="loginForm" novalidate class="space-y-5">
          <div>
            <label class="block text-xs font-semibold text-m2 mb-1.5">Email address</label>
            <input type="email" name="email" required autofocus
              class="w-full bg-s1 border border-white/10 rounded-r8 px-4 py-2.5 text-white placeholder-m1 outline-none focus:border-brand-teal focus:ring-1 focus:ring-brand-teal transition" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-m2 mb-1.5">Password</label>
            <div class="relative">
              <input type="password" name="password" id="passwordInput" required minlength="8"
                class="w-full bg-s1 border border-white/10 rounded-r8 px-4 py-2.5 pr-11 text-white placeholder-m1 outline-none focus:border-brand-teal focus:ring-1 focus:ring-brand-teal transition" />
              <button type="button" id="togglePassword" class="absolute right-3 top-1/2 -translate-y-1/2 text-m1 hover:text-white text-sm">Show</button>
            </div>
          </div>

          <div class="flex items-center justify-between">
            <label class="flex items-center gap-2 text-sm text-m2 cursor-pointer select-none">
              <input type="checkbox" name="rememberMe" class="rounded border-white/20 bg-s1 text-brand-teal focus:ring-brand-teal focus:ring-offset-0" />
              Remember me for 30 days
            </label>
            <a href="/admin/forgot-password" class="text-sm text-brand-teal hover:text-brand-blue transition">Forgot password?</a>
          </div>

          <button type="submit"
            class="w-full flex items-center justify-center gap-2 bg-brand-teal text-ink font-heading font-bold py-3 rounded-r14 hover:brightness-110 active:scale-[0.98] transition disabled:opacity-60 disabled:cursor-not-allowed">
            <svg id="loginSpinner" class="hidden animate-spin h-4 w-4" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
            Log In
          </button>
        </form>
      </div>
    </div>
  </div>

  <script>
    (function initTheme(){
      var saved = localStorage.getItem('theme') || 'dark';
      document.documentElement.classList.toggle('light', saved === 'light');
    })();
    document.getElementById('themeToggle').addEventListener('click', function(){
      var isLight = document.documentElement.classList.toggle('light');
      localStorage.setItem('theme', isLight ? 'light' : 'dark');
    });

    document.getElementById('togglePassword').addEventListener('click', function(){
      var input = document.getElementById('passwordInput');
      var isPw = input.type === 'password';
      input.type = isPw ? 'text' : 'password';
      this.textContent = isPw ? 'Hide' : 'Show';
    });

    var redirectTo = <%- JSON.stringify(typeof redirect !== 'undefined' ? redirect : '') %>;
    document.getElementById('loginForm').addEventListener('submit', async function(e){
      e.preventDefault();
      var form = e.target;
      var btn = form.querySelector('button[type="submit"]');
      var spinner = document.getElementById('loginSpinner');
      var alertBox = document.getElementById('formAlert');
      alertBox.classList.add('hidden');
      spinner.classList.remove('hidden');
      btn.disabled = true;

      try {
        var res = await fetch('/api/login', {
          method: 'POST',
          headers: withCsrfHeaders({ 'Content-Type': 'application/json' }),
          credentials: 'include',
          body: JSON.stringify({
            email: form.email.value,
            password: form.password.value,
            rememberMe: form.rememberMe.checked,
          }),
        });
        var data = await res.json();
        if (!res.ok) throw new Error(data.message || 'Login failed');
        window.location.href = redirectTo || '/admin/dashboard';
      } catch (err) {
        alertBox.textContent = err.message;
        alertBox.classList.remove('hidden');
      } finally {
        spinner.classList.add('hidden');
        btn.disabled = false;
      }
    });
  </script>
</body>
</html>
