<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Forgot Password · Blog Admin</title>
  <link rel="icon" href="/images/favicon.png" />
  <%- include('../partials/tailwind-config') %>
</head>
<body class="font-body bg-ink text-m3 min-h-screen flex items-center justify-center p-6">
  <script src="/js/csrf.js"></script>

  <div class="w-full max-w-sm animate-fadeUp">
    <div class="flex items-center gap-2 font-heading font-extrabold text-xl text-white mb-8 justify-center">
      <img src="/images/logo.png" alt="Embtel" class="h-8 w-auto" onerror="this.style.display='none'" />
      <span>Blog Admin</span>
    </div>

    <div class="bg-s1 border border-white/10 rounded-r20 p-8">
      <h2 class="font-heading font-extrabold text-2xl text-white mb-1">Forgot your password?</h2>
      <p class="text-m2 text-sm mb-6">Enter your email and we'll send you a reset link.</p>

      <div id="formAlert" class="hidden mb-4 px-4 py-3 rounded-r8 text-sm"></div>

      <form id="forgotForm" novalidate class="space-y-5">
        <div>
          <label class="block text-xs font-semibold text-m2 mb-1.5">Email address</label>
          <input type="email" name="email" required autofocus
            class="w-full bg-s2 border border-white/10 rounded-r8 px-4 py-2.5 text-white placeholder-m1 outline-none focus:border-brand-teal focus:ring-1 focus:ring-brand-teal transition" />
        </div>
        <button type="submit"
          class="w-full flex items-center justify-center gap-2 bg-brand-teal text-ink font-heading font-bold py-3 rounded-r14 hover:brightness-110 active:scale-[0.98] transition disabled:opacity-60">
          <svg id="spinner" class="hidden animate-spin h-4 w-4" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
          Send Reset Link
        </button>
        <a href="/admin/login" class="block text-center text-sm text-m2 hover:text-white transition">&larr; Back to login</a>
      </form>
    </div>
  </div>

  <script>
    document.getElementById('forgotForm').addEventListener('submit', async function(e){
      e.preventDefault();
      var form = e.target;
      var btn = form.querySelector('button[type="submit"]');
      var spinner = document.getElementById('spinner');
      var alertBox = document.getElementById('formAlert');
      spinner.classList.remove('hidden');
      btn.disabled = true;

      try {
        var res = await fetch('/api/forgot-password', {
          method: 'POST',
          headers: withCsrfHeaders({ 'Content-Type': 'application/json' }),
          credentials: 'include',
          body: JSON.stringify({ email: form.email.value }),
        });
        var data = await res.json();
        alertBox.className = 'mb-4 px-4 py-3 rounded-r8 text-sm ' + (res.ok ? 'bg-brand-tealDim border border-brand-teal/30 text-brand-teal' : 'bg-red-500/10 border border-red-500/30 text-red-300');
        alertBox.textContent = data.message || (res.ok ? 'Check your email for reset instructions.' : 'Something went wrong.');
      } catch (err) {
        alertBox.className = 'mb-4 px-4 py-3 rounded-r8 text-sm bg-red-500/10 border border-red-500/30 text-red-300';
        alertBox.textContent = 'Network error. Please try again.';
      } finally {
        spinner.classList.add('hidden');
        btn.disabled = false;
      }
    });
  </script>
</body>
</html>
