<div class="flex justify-between items-start flex-wrap gap-3 mb-6">
  <div>
    <h1 class="font-heading font-extrabold text-2xl sm:text-3xl text-white tracking-tight">Categories</h1>
    <p class="text-m2 text-sm mt-1">Organize your blog posts into categories.</p>
  </div>
  <button id="newCategoryBtn" class="flex items-center gap-2 bg-brand-teal text-ink font-heading font-bold text-sm rounded-r8 px-4 py-2.5 hover:brightness-110 transition"><i class="fa-solid fa-plus"></i>New Category</button>
</div>

<div class="bg-s1 border border-white/5 rounded-r20 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-white/5 text-left text-[11px] font-bold uppercase tracking-wider text-m1">
          <th class="px-4 py-3">Image</th>
          <th class="px-4 py-3">Name</th>
          <th class="px-4 py-3">Slug</th>
          <th class="px-4 py-3">Blogs</th>
          <th class="px-4 py-3 text-right">Actions</th>
        </tr>
      </thead>
      <tbody id="categoriesTableBody" class="divide-y divide-white/5">
        <tr><td colspan="5" class="px-4 py-4"><div class="skeleton h-4 w-full rounded animate-shimmer"></div></td></tr>
      </tbody>
    </table>
  </div>
</div>

<div id="categoryModal" class="hidden fixed inset-0 z-[80] flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/70" data-modal-close="categoryModal"></div>
  <div class="relative bg-s1 border border-white/10 rounded-r20 w-full max-w-lg animate-fadeUp">
    <form id="categoryForm">
      <div class="px-6 py-4 border-b border-white/10 flex items-center justify-between">
        <h3 id="categoryModalTitle" class="font-heading font-bold text-white text-sm">New Category</h3>
        <button type="button" data-modal-close="categoryModal" class="w-8 h-8 rounded-r8 text-m2 hover:text-white hover:bg-white/10 transition"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="p-6 space-y-4">
        <input type="hidden" name="categoryId" />
        <div>
          <label class="block text-xs font-semibold text-m2 mb-1.5">Name <span class="text-red-400">*</span></label>
          <input type="text" name="name" required class="w-full bg-s2 border border-white/10 rounded-r8 px-3.5 py-2.5 text-white outline-none focus:border-brand-teal transition" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-m2 mb-1.5">Slug</label>
          <input type="text" name="slug" placeholder="Auto-generated" class="w-full bg-s2 border border-white/10 rounded-r8 px-3.5 py-2.5 text-white placeholder-m1 outline-none focus:border-brand-teal transition" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-m2 mb-1.5">Description</label>
          <textarea name="description" rows="2" class="w-full bg-s2 border border-white/10 rounded-r8 px-3.5 py-2.5 text-white outline-none focus:border-brand-teal transition"></textarea>
        </div>
        <div>
          <label class="block text-xs font-semibold text-m2 mb-1.5">Image URL</label>
          <input type="text" name="image" class="w-full bg-s2 border border-white/10 rounded-r8 px-3.5 py-2.5 text-white outline-none focus:border-brand-teal transition" />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-semibold text-m2 mb-1.5">Meta Title</label>
            <input type="text" name="metaTitle" class="w-full bg-s2 border border-white/10 rounded-r8 px-3.5 py-2.5 text-white outline-none focus:border-brand-teal transition" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-m2 mb-1.5">Meta Description</label>
            <input type="text" name="metaDescription" class="w-full bg-s2 border border-white/10 rounded-r8 px-3.5 py-2.5 text-white outline-none focus:border-brand-teal transition" />
          </div>
        </div>
      </div>
      <div class="px-6 py-4 border-t border-white/10 flex justify-end gap-2">
        <button type="button" data-modal-close="categoryModal" class="px-4 py-2 rounded-r8 text-sm font-medium text-m2 hover:bg-white/5 hover:text-white transition">Cancel</button>
        <button type="submit" class="px-4 py-2 rounded-r8 text-sm font-bold bg-brand-teal text-ink hover:brightness-110 transition">Save</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/categories.js"></script>
