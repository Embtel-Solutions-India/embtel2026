<div class="flex justify-between items-start flex-wrap gap-3 mb-6">
  <div>
    <h1 class="font-heading font-extrabold text-2xl sm:text-3xl text-white tracking-tight">Team Members</h1>
    <p class="text-m2 text-sm mt-1">Manage admin and editor accounts.</p>
  </div>
  <button id="newUserBtn" class="flex items-center gap-2 bg-brand-teal text-ink font-heading font-bold text-sm rounded-r8 px-4 py-2.5 hover:brightness-110 transition"><i class="fa-solid fa-plus"></i>New User</button>
</div>

<div class="bg-s1 border border-white/5 rounded-r20 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-white/5 text-left text-[11px] font-bold uppercase tracking-wider text-m1">
          <th class="px-4 py-3">Name</th>
          <th class="px-4 py-3">Email</th>
          <th class="px-4 py-3">Role</th>
          <th class="px-4 py-3">Status</th>
          <th class="px-4 py-3 text-right">Actions</th>
        </tr>
      </thead>
      <tbody id="usersTableBody" class="divide-y divide-white/5">
        <tr><td colspan="5" class="px-4 py-4"><div class="skeleton h-4 w-full rounded animate-shimmer"></div></td></tr>
      </tbody>
    </table>
  </div>
</div>

<div id="userModal" class="hidden fixed inset-0 z-[80] flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/70" data-modal-close="userModal"></div>
  <div class="relative bg-s1 border border-white/10 rounded-r20 w-full max-w-md animate-fadeUp">
    <form id="userForm">
      <div class="px-6 py-4 border-b border-white/10 flex items-center justify-between">
        <h3 class="font-heading font-bold text-white text-sm">New User</h3>
        <button type="button" data-modal-close="userModal" class="w-8 h-8 rounded-r8 text-m2 hover:text-white hover:bg-white/10 transition"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="p-6 space-y-4">
        <div><label class="block text-xs font-semibold text-m2 mb-1.5">Name</label><input type="text" name="name" required class="w-full bg-s2 border border-white/10 rounded-r8 px-3.5 py-2.5 text-white outline-none focus:border-brand-teal transition" /></div>
        <div><label class="block text-xs font-semibold text-m2 mb-1.5">Email</label><input type="email" name="email" required class="w-full bg-s2 border border-white/10 rounded-r8 px-3.5 py-2.5 text-white outline-none focus:border-brand-teal transition" /></div>
        <div><label class="block text-xs font-semibold text-m2 mb-1.5">Password</label><input type="password" name="password" required minlength="8" class="w-full bg-s2 border border-white/10 rounded-r8 px-3.5 py-2.5 text-white outline-none focus:border-brand-teal transition" /></div>
        <div>
          <label class="block text-xs font-semibold text-m2 mb-1.5">Role</label>
          <select name="role" class="w-full bg-s2 border border-white/10 rounded-r8 px-3.5 py-2.5 text-white outline-none focus:border-brand-teal transition">
            <option value="editor">Editor</option>
            <option value="admin">Admin</option>
          </select>
        </div>
      </div>
      <div class="px-6 py-4 border-t border-white/10 flex justify-end gap-2">
        <button type="button" data-modal-close="userModal" class="px-4 py-2 rounded-r8 text-sm font-medium text-m2 hover:bg-white/5 hover:text-white transition">Cancel</button>
        <button type="submit" class="px-4 py-2 rounded-r8 text-sm font-bold bg-brand-teal text-ink hover:brightness-110 transition">Create</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/users.js"></script>
