<div class="mb-6">
  <h1 class="font-heading font-extrabold text-2xl sm:text-3xl text-white tracking-tight">Comments</h1>
  <p class="text-m2 text-sm mt-1">Moderate reader comments across all blog posts.</p>
</div>

<div class="bg-s1 border border-white/5 rounded-r20 p-4 mb-4">
  <form id="commentFilterForm" class="grid grid-cols-2 md:grid-cols-4 gap-3 items-end">
    <div class="col-span-2">
      <label class="block text-[11px] font-semibold text-m2 mb-1">Search</label>
      <input type="text" name="search" placeholder="Name, email, content…" class="w-full bg-s2 border border-white/10 rounded-r8 px-3 py-2 text-sm text-white placeholder-m1 outline-none focus:border-brand-teal transition" />
    </div>
    <div>
      <label class="block text-[11px] font-semibold text-m2 mb-1">Status</label>
      <select name="status" class="w-full bg-s2 border border-white/10 rounded-r8 px-3 py-2 text-sm text-white outline-none focus:border-brand-teal transition">
        <option value="">All</option>
        <option value="pending">Pending</option>
        <option value="approved">Approved</option>
        <option value="rejected">Rejected</option>
        <option value="spam">Spam</option>
      </select>
    </div>
    <button type="submit" class="bg-white/5 hover:bg-white/10 text-white rounded-r8 px-3 py-2 text-sm font-medium transition"><i class="fa-solid fa-magnifying-glass"></i></button>
  </form>
</div>

<div class="bg-s1 border border-white/5 rounded-r20 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-white/5 text-left text-[11px] font-bold uppercase tracking-wider text-m1">
          <th class="px-4 py-3">Author</th>
          <th class="px-4 py-3">Comment</th>
          <th class="px-4 py-3">Blog</th>
          <th class="px-4 py-3">Status</th>
          <th class="px-4 py-3 text-right">Actions</th>
        </tr>
      </thead>
      <tbody id="commentsTableBody" class="divide-y divide-white/5">
        <tr><td colspan="5" class="px-4 py-4"><div class="skeleton h-4 w-full rounded animate-shimmer"></div></td></tr>
      </tbody>
    </table>
  </div>
</div>

<script src="/js/comments.js"></script>
