# --- Server ---
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
# The main embtel-final marketing site — linked from the blog's header/footer
MAIN_SITE_URL=https://embtelsolutions.com
# Origins allowed to call the public read-only API (comma-separated)
CORS_ORIGINS=http://localhost:8811,https://embtelsolutions.com,https://www.embtelsolutions.com

# --- Database ---
MONGO_URI=mongodb://127.0.0.1:27017/blog_admin
# For MongoDB Atlas, use a connection string like:
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster-url>/blog_admin?retryWrites=true&w=majority

# --- Auth ---
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=1d
JWT_COOKIE_EXPIRES_DAYS=1
SESSION_SECRET=change_this_session_secret_too
RESET_TOKEN_EXPIRES_MINUTES=30

# --- Default admin (used by seed script) ---
SEED_ADMIN_NAME=Site Admin
SEED_ADMIN_EMAIL=admin@embtel.com
SEED_ADMIN_PASSWORD=Admin@12345

# --- Rich text editor ---
# Optional — if set, the editor loads from TinyMCE Cloud with this key instead
# of the bundled self-hosted copy (which needs no key and already works fine).
TINYMCE_API_KEY=

# --- Uploads ---
MAX_UPLOAD_MB=5
# Media (featured images, gallery, media library) is stored in S3 — Render's
# own disk is ephemeral and wipes uploads on every redeploy/restart.
AWS_S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional — only set this if serving media through CloudFront/a custom
# domain instead of the bucket's own https://<bucket>.s3.<region>.amazonaws.com URL.
AWS_S3_PUBLIC_URL_BASE=

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=300
LOGIN_RATE_LIMIT_MAX=10

# --- Email (used for password reset; leave blank to log reset links to console instead) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Blog Admin <no-reply@embtel.com>"
